using EventEase.Models
@model EventEase.Models.BookingDto
@{
}


<div class="row">
	<div class="col-md-8 mx-auto rounded boarder p-3">
		<h2 class="text-center mb-5">Edit Booking</h2>

		<form method="post" enctype="multipart/form-data">

			<div class="row mb-3">
				<label class="col-sm-4 col-form-label">Booking Id</label>
				<div class="col-sm-8">
					<input class="form-control" value="">
					
				</div>
			</div><div class="row mb-3">
				<label class="col-sm-4 col-form-label">Event Id</label>
				<div class="col-sm-8">
					<input class="form-control" asp-for="EventId">
					<span asp-validation-for="EventId" class="text-danger"></span>
				</div>
			</div>
			<div class="row mb-3">
				<label class="col-sm-4 col-form-label">Venue Id</label>
				<div class="col-sm-8">
					<input class="form-control" asp-for="VenueId">
					<span asp-validation-for="VenueId" class="text-danger"></span>
				</div>
			</div>


			<div class="row">
				<div class="offset-sm-4 col-sm-4 d-grid">
					<button type="submit" class="btn btn-primary">Submit</button>
				</div>
				<div class="col-sm-4 d-grid">
					<a class="btn btn-outline-primary" asp-controller="Booking" asp-action="Index" role="button">Cancel</a>
				</div>
			</div>

		</form>

	</div>
</div>
